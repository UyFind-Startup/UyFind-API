// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Developer {
    id         Int      @id @default(autoincrement())
    name       String
    email      String?  @unique
    passwordHash String?
    qrCodeUrl  String?
    telegramChatId       String?   @map("telegram_chat_id")
    telegramLinkToken      String?   @unique @map("telegram_link_token")
    telegramLinkExpiresAt  DateTime? @map("telegram_link_expires_at")
    createdAt  DateTime @default(now())

    projects Project[]
    sessions DeveloperSession[]
    memberships ProjectMember[]

    @@map("developers")
}

model Project {
    id           Int     @id @default(autoincrement())
    name         String
    location     String
    district     String?
    description  String?
    advantages   String[]
    mapEmbedUrl  String?
    qrCodeUrl    String?
    totalFloors  Int?
    totalUnits   Int?
    badgeVerified Boolean @default(false)
    badgeTrusted  Boolean @default(false)
    topInCatalog  Boolean @default(false)
    topInHome     Boolean @default(false)
    deliveryDate String
    imageUrl     String  @default("https://via.placeholder.com/800x600?text=Project+Image")
    videoUrl     String?
    developerId  Int

    developer  Developer   @relation(fields: [developerId], references: [id], onDelete: Cascade)
    apartments Apartment[]
    leads      Lead[]
    media      ProjectMedia[]
    reviews    ProjectReview[]
    members    ProjectMember[]
    subscription ProjectSubscription?
    billingInvoices BillingInvoice[]

    @@index([developerId])
    @@map("projects")
}

enum ProjectMemberRole {
    OWNER
    MANAGER
}

model ProjectMember {
    id          Int @id @default(autoincrement())
    projectId   Int
    developerId Int
    role        ProjectMemberRole @default(MANAGER)
    createdAt   DateTime @default(now())

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

    @@unique([projectId, developerId])
    @@index([developerId])
    @@map("project_members")
}

model DeveloperSession {
    id          Int      @id @default(autoincrement())
    developerId Int
    token       String   @unique
    expiresAt   DateTime
    createdAt   DateTime @default(now())

    developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

    @@index([developerId])
    @@index([token])
    @@map("developer_sessions")
}

enum SubscriptionPlan {
    START
    PRO
    PREMIUM
    ULTIMATE
}

enum SubscriptionStatus {
    TRIAL
    ACTIVE
    PAST_DUE
    CANCELED
    EXPIRED
}

enum BillingProvider {
    PAYME
    CLICK
}

model ProjectSubscription {
    id            Int                @id @default(autoincrement())
    projectId     Int                @unique
    plan          SubscriptionPlan   @default(START)
    status        SubscriptionStatus @default(TRIAL)
    trialStartsAt DateTime?
    trialEndsAt   DateTime?
    currentPeriodStart DateTime?
    currentPeriodEnd   DateTime?
    provider      BillingProvider?
    externalRef   String?
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([status])
    @@index([plan])
    @@map("project_subscriptions")
}

model BillingInvoice {
    id             Int             @id @default(autoincrement())
    projectId      Int
    provider       BillingProvider
    amountUsd      Int
    status         String          @default("PENDING")
    externalRef    String?         @unique
    checkoutUrl    String?
    metadata       Json?
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@index([provider, status])
    @@map("billing_invoices")
}

model BillingWebhookEvent {
    id          Int      @id @default(autoincrement())
    provider    BillingProvider
    externalRef String
    status      String
    signature   String?
    createdAt   DateTime @default(now())

    @@unique([provider, externalRef, status])
    @@index([externalRef])
    @@map("billing_webhook_events")
}

model Apartment {
    id        Int     @id @default(autoincrement())
    projectId Int
    price     Float
    rooms     Int
    area      Float
    floor     Int
    imageUrl  String?

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    leads   Lead[]

    @@index([projectId])
    @@map("apartments")
}

enum LeadStatus {
    NEW
    CONTACTED
}

model Lead {
    id          Int        @id @default(autoincrement())
    name        String
    phone       String
    apartmentId Int?
    projectId   Int?
    status      LeadStatus @default(NEW)
    createdAt   DateTime   @default(now())

    apartment Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
    project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    feedback  LeadFeedback?

    @@index([projectId])
    @@index([status])
    @@index([apartmentId])
    @@map("leads")
}

model ProjectMedia {
    id        Int      @id @default(autoincrement())
    projectId Int
    imageUrl  String
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_media")
}

model ProjectReview {
    id        Int      @id @default(autoincrement())
    projectId Int
    rating    Int
    comment   String?
    createdAt DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_reviews")
}

model LeadFeedback {
    id           Int      @id @default(autoincrement())
    leadId       Int      @unique
    token        String   @unique
    rating       Int?
    comment      String?
    submittedAt  DateTime?
    createdAt    DateTime @default(now())

    lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

    @@index([token])
    @@map("lead_feedback")
}
