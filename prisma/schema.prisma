// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Developer {
    id         Int      @id @default(autoincrement())
    name       String
    email      String?  @unique
    passwordHash String?
    qrCodeUrl  String?
    phone              String?
    legalAddress       String?  @map("legal_address")
    officeAddress      String?  @map("office_address")
    website            String?
    description        String?
    logoUrl            String?  @map("logo_url")
    telegramChatId       String?   @map("telegram_chat_id")
    telegramLinkToken      String?   @unique @map("telegram_link_token")
    telegramLinkExpiresAt  DateTime? @map("telegram_link_expires_at")
    createdAt  DateTime @default(now())

    projects Project[]
    sessions DeveloperSession[]
    memberships ProjectMember[]
    devices DeveloperDevice[]
    promoRedemptions PromoRedemption[]

    @@map("developers")
}

model DeveloperDevice {
    id            Int      @id @default(autoincrement())
    developerId   Int      @map("developer_id")
    expoPushToken String   @unique @map("expo_push_token")
    platform      String?
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

    @@index([developerId])
    @@map("developer_devices")
}

model Project {
    id           Int     @id @default(autoincrement())
    name         String
    location     String
    district     String?
    description  String?
    advantages   String[]
    materials    String[] @default([])
    hasInstallment Boolean @default(false) @map("has_installment")
    buildingCount  Int?    @map("building_count")
    corpusCount    Int?    @map("corpus_count")
    ceilingHeightM Float?  @map("ceiling_height_m")
    hasSurfaceParking     Boolean @default(false) @map("has_surface_parking")
    hasUndergroundParking Boolean @default(false) @map("has_underground_parking")
    surfaceParkingSpaces     Int? @map("surface_parking_spaces")
    undergroundParkingSpaces Int? @map("underground_parking_spaces")
    elevatorsCount Int?    @map("elevators_count")
    latitude     Float?
    longitude    Float?
    mapEmbedUrl  String?
    qrCodeUrl    String?
    totalFloors  Int?
    totalUnits   Int?
    badgeVerified Boolean @default(false)
    badgeTrusted  Boolean @default(false)
    topInCatalog  Boolean @default(false)
    topInHome     Boolean @default(false)
    deliveryDate String
    imageUrl     String  @default("")
    videoUrl     String?
    developerId  Int

    developer Developer   @relation(fields: [developerId], references: [id], onDelete: Cascade)
    floors    ProjectFloor[]
    leads      Lead[]
    media      ProjectMedia[]
    reviews    ProjectReview[]
    members    ProjectMember[]
    subscription ProjectSubscription?
    billingInvoices BillingInvoice[]
    progressMilestones ProjectProgressMilestone[]
    promoRedemptions PromoRedemption[]
    apartmentUnits   ApartmentUnit[]
    layoutVariants   LayoutVariant[]
    customers        Customer[]
    buildingProgress BuildingProgress?

    @@index([developerId])
    @@map("projects")
}

model ProjectProgressMilestone {
    id        Int      @id @default(autoincrement())
    projectId Int      @map("project_id")
    title     String
    sortOrder Int      @default(0) @map("sort_order")
    done      Boolean  @default(false)
    photoUrls String[] @default([]) @map("photo_urls")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_progress_milestones")
}

enum ProjectMemberRole {
    OWNER
    MANAGER
}

model ProjectMember {
    id          Int @id @default(autoincrement())
    projectId   Int
    developerId Int
    role        ProjectMemberRole @default(MANAGER)
    createdAt   DateTime @default(now())

    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
    developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

    @@unique([projectId, developerId])
    @@index([developerId])
    @@map("project_members")
}

model DeveloperSession {
    id          Int      @id @default(autoincrement())
    developerId Int
    token       String   @unique
    expiresAt   DateTime
    createdAt   DateTime @default(now())

    developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

    @@index([developerId])
    @@index([token])
    @@map("developer_sessions")
}

enum SubscriptionPlan {
    START
    PRO
    PREMIUM
    ULTIMATE
}

enum SubscriptionStatus {
    TRIAL
    ACTIVE
    PAST_DUE
    CANCELED
    EXPIRED
}

enum BillingProvider {
    PAYME
    CLICK
}

enum PromoBenefitType {
    FREE_DAYS
    PERCENT_OFF
}

model ProjectSubscription {
    id            Int                @id @default(autoincrement())
    projectId     Int                @unique
    plan          SubscriptionPlan   @default(START)
    status        SubscriptionStatus @default(TRIAL)
    trialStartsAt DateTime?
    trialEndsAt   DateTime?
    currentPeriodStart DateTime?
    currentPeriodEnd   DateTime?
    provider      BillingProvider?
    externalRef   String?
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([status])
    @@index([plan])
    @@map("project_subscriptions")
}

model PromoCode {
    id               Int              @id @default(autoincrement())
    code             String           @unique
    description      String?
    benefitType      PromoBenefitType @map("benefit_type")
    freeDays         Int?             @map("free_days")
    percentOff       Int?             @map("percent_off")
    plan             SubscriptionPlan?
    startsAt         DateTime?        @map("starts_at")
    expiresAt        DateTime?        @map("expires_at")
    maxRedemptions   Int?             @map("max_redemptions")
    redeemedCount    Int              @default(0) @map("redeemed_count")
    active           Boolean          @default(true)
    createdAt        DateTime         @default(now()) @map("created_at")
    updatedAt        DateTime         @updatedAt @map("updated_at")

    redemptions PromoRedemption[]

    @@index([active])
    @@index([expiresAt])
    @@map("promo_codes")
}

model PromoRedemption {
    id          Int      @id @default(autoincrement())
    promoCodeId Int      @map("promo_code_id")
    developerId Int?     @map("developer_id")
    projectId   Int?     @map("project_id")
    redeemedAt  DateTime @default(now()) @map("redeemed_at")

    promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
    developer Developer? @relation(fields: [developerId], references: [id], onDelete: SetNull)
    project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

    @@index([promoCodeId])
    @@index([developerId])
    @@index([projectId])
    @@unique([promoCodeId, developerId, projectId])
    @@map("promo_redemptions")
}

model BillingInvoice {
    id             Int             @id @default(autoincrement())
    projectId      Int
    provider       BillingProvider
    amountUsd      Int
    status         String          @default("PENDING")
    externalRef    String?         @unique
    checkoutUrl    String?
    metadata       Json?
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@index([provider, status])
    @@map("billing_invoices")
}

model BillingWebhookEvent {
    id          Int      @id @default(autoincrement())
    provider    BillingProvider
    externalRef String
    status      String
    signature   String?
    createdAt   DateTime @default(now())

    @@unique([provider, externalRef, status])
    @@index([externalRef])
    @@map("billing_webhook_events")
}

model ProjectFloor {
    id         Int      @id @default(autoincrement())
    projectId  Int
    floor      Int
    pricePerM2 Float    @map("price_per_m2")
    title      String?
    sortOrder  Int      @default(0) @map("sort_order")
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @updatedAt @map("updated_at")

    project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    areaOptions  ProjectFloorAreaOption[]
    layouts      ProjectFloorLayout[]
    leads        Lead[]

    @@unique([projectId, floor])
    @@index([projectId])
    @@map("project_floors")
}

model ProjectFloorAreaOption {
    id             Int   @id @default(autoincrement())
    projectFloorId Int   @map("project_floor_id")
    areaSqm        Float @map("area_sqm")
    sortOrder      Int   @default(0) @map("sort_order")

    floor ProjectFloor @relation(fields: [projectFloorId], references: [id], onDelete: Cascade)

    @@index([projectFloorId])
    @@map("project_floor_area_options")
}

model ProjectFloorLayout {
    id             Int    @id @default(autoincrement())
    projectFloorId Int    @map("project_floor_id")
    imageUrl       String @map("image_url")
    title          String?
    sortOrder      Int    @default(0) @map("sort_order")

    floor          ProjectFloor   @relation(fields: [projectFloorId], references: [id], onDelete: Cascade)
    layoutVariant  LayoutVariant?

    @@index([projectFloorId])
    @@map("project_floor_layouts")
}

/// Шаблон планировки: привязан к существующей записи project_floor_layouts (картинка плана в каталоге/3D-витрине).
model LayoutVariant {
    id                   Int      @id @default(autoincrement())
    projectId            Int      @map("project_id")
    projectFloorLayoutId Int      @unique @map("project_floor_layout_id")
    code                 String?
    model3dUrl           String?  @map("model_3d_url")
    createdAt            DateTime @default(now()) @map("created_at")
    updatedAt            DateTime @updatedAt @map("updated_at")

    project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
    projectFloorLayout  ProjectFloorLayout @relation(fields: [projectFloorLayoutId], references: [id], onDelete: Cascade)
    apartmentUnits      ApartmentUnit[]

    @@index([projectId])
    @@map("layout_variants")
}

enum LeadStatus {
    NEW
    CONTACTED
    MEETING
    RESERVED
    SOLD
    CANCELED
}

enum ApartmentStatus {
    AVAILABLE
    RESERVED
    SOLD
}

enum CustomerPaymentType {
    DEPOSIT
    INSTALLMENT
    FULL
    OTHER
}

enum ConstructionStageKey {
    FOUNDATION
    FRAME
    FACADE
    INTERIOR
    LANDSCAPING
}

/// Конкретная квартира (шахматка / CRM). План и 3D по умолчанию берутся из связанного LayoutVariant → ProjectFloorLayout.
model ApartmentUnit {
    id              Int             @id @default(autoincrement())
    projectId       Int             @map("project_id")
    layoutVariantId Int?            @map("layout_variant_id")
    number          String
    floor           Int
    rooms           Int
    areaSqm         Float           @map("area_sqm")
    priceUzs        Int?            @map("price_uzs")
    status          ApartmentStatus @default(AVAILABLE)
    /// Ручной override картинки плана (если null — imageUrl из layout variant / floor layout).
    layoutImageUrl  String?         @map("layout_image_url")
    /// Ручной override 3D URL (если null — model3dUrl из layout variant).
    model3dUrl      String?         @map("model_3d_url")
    crmMetadata     Json?           @map("crm_metadata")
    sortOrder       Int             @default(0) @map("sort_order")
    createdAt       DateTime        @default(now()) @map("created_at")
    updatedAt       DateTime        @updatedAt @map("updated_at")

    project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
    layoutVariant LayoutVariant? @relation(fields: [layoutVariantId], references: [id], onDelete: SetNull)
    customers     Customer[]
    leads         Lead[]

    @@unique([projectId, number])
    @@index([projectId, floor])
    @@index([projectId, status])
    @@index([layoutVariantId])
    @@map("apartments")
}

model BuildingProgress {
    id              Int      @id @default(autoincrement())
    projectId       Int      @unique @map("project_id")
    percentComplete Int      @default(0) @map("percent_complete")
    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
    stages  ConstructionStage[]

    @@map("building_progress")
}

model ConstructionStage {
    id                 Int                  @id @default(autoincrement())
    buildingProgressId Int                  @map("building_progress_id")
    stageKey           ConstructionStageKey @map("stage_key")
    done               Boolean              @default(false)
    sortOrder          Int                  @default(0) @map("sort_order")

    buildingProgress BuildingProgress @relation(fields: [buildingProgressId], references: [id], onDelete: Cascade)

    @@unique([buildingProgressId, stageKey])
    @@index([buildingProgressId])
    @@map("construction_stages")
}

model Customer {
    id            Int      @id @default(autoincrement())
    projectId     Int      @map("project_id")
    apartmentId   Int?     @map("apartment_id")
    name          String
    phone         String
    accessCode    String   @unique @map("access_code")
    verificationToken String? @unique @map("verification_token")
    totalPriceUzs Int?     @map("total_price_uzs")
    notes         String?
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
    apartment  ApartmentUnit?      @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
    payments   CustomerPayment[]
    documents  CustomerDocument[]
    sessions   CustomerSession[]

    @@index([projectId])
    @@index([phone])
    @@map("customers")
}

model CustomerSession {
    id         Int      @id @default(autoincrement())
    customerId Int      @map("customer_id")
    token      String   @unique
    expiresAt  DateTime @map("expires_at")
    createdAt  DateTime @default(now()) @map("created_at")

    customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

    @@index([customerId])
    @@index([token])
    @@map("customer_sessions")
}

model CustomerPayment {
    id         Int                 @id @default(autoincrement())
    customerId Int                 @map("customer_id")
    amountUzs  Int                 @map("amount_uzs")
    paidAt     DateTime            @map("paid_at")
    comment    String?
    type       CustomerPaymentType @default(OTHER) @map("type")
    createdAt  DateTime            @default(now()) @map("created_at")
    updatedAt  DateTime            @updatedAt @map("updated_at")

    customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

    @@index([customerId])
    @@map("customer_payments")
}

model CustomerDocument {
    id          Int      @id @default(autoincrement())
    customerId  Int      @map("customer_id")
    title       String
    fileUrl     String   @map("file_url")
    mimeType    String?  @map("mime_type")
    isContract  Boolean  @default(false) @map("is_contract")
    createdAt   DateTime @default(now()) @map("created_at")

    customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

    @@index([customerId])
    @@map("customer_documents")
}

model Lead {
    id          Int        @id @default(autoincrement())
    name        String
    phone       String
    floorId     Int?       @map("floor_id")
    projectId   Int?
    apartmentId Int?       @map("apartment_id")
    status      LeadStatus @default(NEW)
    createdAt   DateTime   @default(now())

    floor     ProjectFloor? @relation(fields: [floorId], references: [id], onDelete: SetNull)
    project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
    apartment ApartmentUnit? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
    feedback  LeadFeedback?

    @@index([projectId])
    @@index([status])
    @@index([floorId])
    @@index([apartmentId])
    @@map("leads")
}

model ProjectMedia {
    id        Int      @id @default(autoincrement())
    projectId Int
    imageUrl  String
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_media")
}

model ProjectReview {
    id        Int      @id @default(autoincrement())
    projectId Int
    rating    Int
    comment   String?
    createdAt DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_reviews")
}

model LeadFeedback {
    id           Int      @id @default(autoincrement())
    leadId       Int      @unique
    token        String   @unique
    rating       Int?
    comment      String?
    submittedAt  DateTime?
    createdAt    DateTime @default(now())

    lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

    @@index([token])
    @@map("lead_feedback")
}
